{
    "name": "feedback-popup",
    "version": "3.0.1",
    "description": "A simple to use popup for collecting feedback from users about issues with the site that they are using. Currently it captures a screenshot of the users browser, the users OS and browser name + version and also a message from the user. This is all then sent to an API, where you can do whatever you like with the information.",
    "private": false,
    "main": "dist/library.js",
    "types": "dist/library.d.ts",
    "files": [
        "dist",
        "README.md",
        "LICENSE"
    ],
    "scripts": {
        "start": "parcel src/index.html -p 3000 --target app",
        "api": "node server.js",
        "dev": "concurrently \"pnpm run api\" \"pnpm start\"",
        "build": "pnpm run clean && parcel build src/index.html --public-url '.' --target app",
        "build:lib": "pnpm run clean && tsc --project tsconfig.lib.json",
        "build:all": "pnpm run build && pnpm run build:lib",
        "clean": "rm -rf lib .parcel-cache dist",
        "prepublishOnly": "pnpm run build:all",
        "publish:npm": "pnpm run build:all && npm publish",
        "test": "vitest",
        "test:ui": "vitest --ui",
        "test:run": "vitest run",
        "release": "np --no-release-draft",
        "release:gh": "np --no-release-draft && gh release create v$(node -p \"require('./package.json').version\") --generate-notes",
        "release:patch": "np patch --no-release-draft",
        "release:minor": "np minor --no-release-draft",
        "release:major": "np major --no-release-draft",
        "release:beta": "np prerelease --tag=beta",
        "release:preview": "np --preview",
        "release:any-branch": "np --any-branch"
    },
    "dependencies": {
        "html2canvas": "^1.4.1",
        "ua-parser-js": "^2.0.3"
    },
    "devDependencies": {
        "@parcel/config-default": "^2.16.0",
        "@parcel/transformer-css": "^2.16.0",
        "@parcel/transformer-html": "^2.16.0",
        "@parcel/transformer-postcss": "^2.16.0",
        "@parcel/transformer-typescript-tsc": "^2.16.0",
        "@vitest/ui": "^4.0.17",
        "body-parser": "^2.2.0",
        "concurrently": "^8.2.2",
        "cors": "^2.8.5",
        "eslint": "^9.21.0",
        "express": "^5.1.0",
        "jsdom": "^27.4.0",
        "np": "^10.0.0",
        "parcel": "^2.16.0",
        "postcss": "^8.2.1",
        "typescript": "^5.8.3",
        "vitest": "^4.0.17"
    },
    "author": {
        "name": "Tommy Scribble",
        "email": "tommy@scribbledesign.co.uk",
        "url": "https://github.com/TommyScribble"
    },
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/TommyScribble/feedback-popup.git"
    },
    "bugs": {
        "url": "https://github.com/TommyScribble/feedback-popup/issues"
    },
    "homepage": "https://github.com/TommyScribble/feedback-popup#readme",
    "keywords": [
        "feedback",
        "popup",
        "screenshot",
        "user-feedback",
        "bug-report",
        "typescript",
        "javascript",
        "browser",
        "ui",
        "ux"
    ],
    "sideEffects": false,
    "engines": {
        "node": ">=14.0.0"
    },
    "targets": {
        "app": {
            "context": "browser",
            "publicUrl": "."
        }
    },
    "volta": {
        "node": "22.14.0"
    }
}
